# Datos de configuración para la aplicación Alzhecare API
APP_NAME=Alzhecare API
DEBUG=false
SECRET_KEY=replace_with_minimum_24_chars_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

# PostgreSQL / Supabase 
# Recommendado: usar la conexion por pooler
# Formato: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql+psycopg://postgres.your_project_ref:your_password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# True: se ejecuta app/db/schema_normalized.sql
SQL_AUTO_INIT=false

# Verifica la existencia de tablas en la base de datos al iniciar la app
SQL_VERIFY_SCHEMA_ON_STARTUP=true

# Semilla para generar usuarios de prueba en la base de datos
SQL_SEED_TEST_USERS=false
SQL_TEST_USERS_PASSWORD=ChangeMe123!

# Modelo de PyTorch para el diagnóstico de Alzheimer
TORCH_MODEL_PATH=app/models/v1/alzheimer_ensemble_v1.pth
TORCH_LABEL_CLASSES_PATH=app/models/v1/le_classes.pkl
TORCH_DEVICE=auto

# AWS S3 para almacenamiento de análisis y perfiles
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name
AWS_S3_BASE_PATH=analyses
AWS_S3_PROFILE_BASE_PATH=profiles
SIGNED_URL_EXPIRES_SECONDS=3600
